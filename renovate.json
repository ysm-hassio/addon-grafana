{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rebaseWhen": "behind-base-branch",
  "dependencyDashboard": true,
  "labels": ["dependencies", "no-stale"],
  "commitMessagePrefix": "⬆️",
  "commitMessageTopic": "{{depName}}",
  "forkProcessing": "enabled",
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["/Dockerfile$", "/build.yaml$"],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "ARG BUILD_FROM=(?<depName>.*?):(?<currentValue>.*?)\\s+",
        "(aarch64|amd64):\\s[\"']?(?<depName>.*?):(?<currentValue>.*?)[\"']?\\s"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": ["/Dockerfile$"],
      "matchStringsStrategy": "any",
      "matchStrings": [
        "\\s\\s(?<package>[a-z0-9][a-z0-9-]+)=(?<currentValue>[a-z0-9-:_+~.]+)\\s+"
      ],
      "versioningTemplate": "deb",
    "datasourceTemplate": "apt",
    "depNameTemplate": "{{package}}",
    "registryUrls": [
      "http://deb.debian.org/debian/dists/bookworm/main/binary-amd64/Packages",
      "http://security.debian.org/debian-security/dists/bookworm-security/main/binary-amd64/Packages"
    ]
    },
    {
      "customType": "regex",
      "fileMatch": ["/Dockerfile$"],
      "matchStrings": [
        "ARG GRAFANA_VERSION=[\"']?(?<currentValue>.+?)[\"']?\\s+"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "grafana/grafana"
    },
    {
      "customType": "regex",
      "fileMatch": ["/Dockerfile$"],
      "matchStrings": [
        "ARG GRAFANA_IMAGE_RENDERER_VERSION=[\"']?(?<currentValue>.+?)[\"']?\\s+"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "grafana/grafana-image-renderer"
    },
    {
      "customType": "regex",
      "fileMatch": ["/Dockerfile$"],
      "matchStrings": [
        "ARG VICTORIAMETRICS_DATASOURCE_VERSION=[\"']?(?<currentValue>.+?)[\"']?\\s+"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "VictoriaMetrics/victoriametrics-datasource"
    }
  ],
  "packageRules": [
    {
      "groupName": "Add-on base image",
      "matchDatasources": ["docker"]
    },
    {
      "groupName": "Add-on base image",
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchDatasources": ["github-releases"],
      "matchUpdateTypes": ["minor", "patch"]
    }
  ]
}
